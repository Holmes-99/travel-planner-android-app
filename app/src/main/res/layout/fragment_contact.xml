<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#FBF5DD">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Contact Us"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#0D530E"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="We're here to help you plan your perfect trip"
        android:textSize="14sp"
        android:textColor="#306D29"
        android:gravity="center"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/button_call"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📞 Call Us"
        android:backgroundTint="#0D530E"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/button_locate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📍 Locate Us"
        android:backgroundTint="#306D29"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/button_email"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="✉ Email Us"
        android:backgroundTint="#0D530E"
        android:textColor="#FFFFFF"
        android:textSize="16sp"/>

</LinearLayout>